# App
NODE_ENV=development
APP_URL=http://localhost:5173
PORT=3001

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/tradingjourney
REDIS_URL=redis://localhost:6379

# JWT (generate with: openssl genrsa -out private.pem 2048)
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Encryption
VAULT_MASTER_SALT=<random-32-byte-hex>

# WebAuthn
WEBAUTHN_RP_NAME=TradingJourney Pro
WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost:5173

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxx
FROM_EMAIL=noreply@yourdomain.com

# Push Notifications
VAPID_PUBLIC_KEY=<generate with web-push>
VAPID_PRIVATE_KEY=<generate with web-push>
VAPID_EMAIL=mailto:admin@yourdomain.com

# News APIs
ALPHA_VANTAGE_API_KEY=xxxxxxxxxxxx
NEWSAPI_KEY=xxxxxxxxxxxx

# Economic Calendar
TRADING_ECONOMICS_API_KEY=xxxxxxxxxxxx

# Cloudflare (for IP reputation checks)
CLOUDFLARE_API_TOKEN=xxxxxxxxxxxx

# hCaptcha
HCAPTCHA_SITE_KEY=xxxxxxxxxxxx
HCAPTCHA_SECRET_KEY=xxxxxxxxxxxx

# Storage
S3_BUCKET=tradingjourney-uploads
S3_REGION=auto
S3_ENDPOINT=https://xxxx.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=xxxxxxxxxxxx
S3_SECRET_ACCESS_KEY=xxxxxxxxxxxx

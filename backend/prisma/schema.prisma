generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String   @id @default(uuid())
  email             String   @unique
  emailVerified     Boolean  @default(false)
  passwordHash      String
  totpSecret        String?
  totpEnabled       Boolean  @default(false)
  backupPinHash     String?
  recoveryCodes     Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  deletedAt         DateTime?
  webauthnCredentials WebauthnCredential[]
  brokerVault       BrokerVault[]
  journalEntries    JournalEntry[]
  notebookEntries   NotebookEntry[]
  auditLog          AuditLog[]
  sessions          Session[]
}

model WebauthnCredential {
  id           String   @id @default(uuid())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String
  credentialId String   @unique
  publicKey    String
  deviceName   String?
  createdAt    DateTime @default(now())
  lastUsedAt   DateTime?
}

model BrokerVault {
  id                 String   @id @default(uuid())
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId             String
  brokerName         String
  encryptedCredentials String
  encryptionIv       String
  vaultPinAttempts   Int      @default(0)
  vaultLockedUntil   DateTime?
  connectedAt        DateTime @default(now())
}

model JournalEntry {
  id                 String   @id @default(uuid())
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId             String
  brokerTradeId      String?
  pair               String
  direction          Direction
  lotSize            Decimal?
  entryPrice         Decimal?
  exitPrice          Decimal?
  entryTime          DateTime?
  exitTime           DateTime?
  grossPnl           Decimal?
  preTradePlan       String?
  postTradeReview    String?
  lessons            String?
  setupRating        Int?     @db.Integer
  emotionEntry       String?
  followedPlan       FollowedPlan?
  strategyTag        String?
  screenshotEntryUrl String?
  screenshotExitUrl  String?
  replayAnnotations  Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

enum Direction {
  BUY
  SELL
}

enum FollowedPlan {
  YES
  NO
  PARTIAL
}

model NotebookEntry {
  id           String   @id @default(uuid())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String
  title        String?
  content      Json
  tags         String[]
  category     String?
  isPinned     Boolean  @default(false)
  isArchived   Boolean  @default(false)
  searchVector Unsupported("tsvector")?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AuditLog {
  id        BigInt   @id @default(autoincrement())
  user      User?    @relation(fields: [userId], references: [id])
  userId    String?
  eventType String
  eventData Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
}

model Session {
  id                String   @id @default(uuid())
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId            String
  refreshTokenHash  String   @unique
  deviceFingerprint String
  deviceName        String?
  ipAddress         String?
  lastActiveAt      DateTime @default(now())
  expiresAt         DateTime
  revoked           Boolean  @default(false)
}
